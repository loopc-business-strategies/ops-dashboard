PORT=5000
DB_NAME=ops-dashboard
DEFAULT_TENANT=loopc
NODE_ENV=development

# Shared coordination (recommended for multi-instance Railway)
# REDIS_URL=

# Error reporting — see docs/OBSERVABILITY-SENTRY.md
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0

# One-time bootstrap in production — see ENV-VARS-QUICK-REFERENCE.md
# ENABLE_SETUP=false
# SETUP_TOKEN=

# DNS override for MongoDB Atlas SRV resolution (server startup; scripts may use ATLAS_DNS_SERVERS)
# DNS_SERVERS=8.8.8.8,8.8.4.4

# Socket.IO CORS origin for realtime (optional; merged with CLIENT_URLS)
# FRONTEND_URL=

# Persistent uploads on Railway volume — see ENV-VARS-QUICK-REFERENCE.md
# UPLOAD_STORAGE_ROOT=/app/uploads
# RAILWAY_VOLUME_MOUNT_PATH=/app/uploads

# Upload size limits (optional)
# TRANSACTION_ATTACHMENT_MAX_BYTES=
# VENDOR_DOCUMENT_MAX_BYTES=

# Notification digest background job (optional)
# NOTIFICATION_DIGEST_JOB=false

# ERP report / bridge rate limits (optional)
# METAL_RATES_BRIDGE_RATE_LIMIT_WINDOW_MS=
# METAL_RATES_BRIDGE_RATE_LIMIT_MAX=
# ERP_REPORT_RATE_LIMIT_WINDOW_MS=
# ERP_REPORT_RATE_LIMIT_MAX=

# Optional tenant registry override (JSON)
# TENANT_REGISTRY_JSON=

# Required tenant database URIs. Each tenant should point at its own MongoDB database/cluster.
MONGO_URI_MG=
MONGO_URI_CG=
MONGO_URI_LOOPC=

# Optional — Atlas Admin API for automated backup/snapshot drills (npm run verify:atlas-backup-drill)
# Atlas → Organization → Access Manager → API Keys → Create (Organization Project Owner read)
# ATLAS_PUBLIC_KEY=
# ATLAS_PRIVATE_KEY=
# ATLAS_GROUP_ID_MG=     # Project MG → Settings → General → Project ID
# ATLAS_GROUP_ID_CG=     # Project CG
# ATLAS_GROUP_ID_LOOPC=  # Project LoopC
# ATLAS_UI_BACKUP_CONFIRMED=mg,cg,loopc   # after manual Atlas UI Backup check
# ATLAS_RESTORE_DRILL_URI=                  # optional: connection string for mg-restore-drill cluster
# ATLAS_RESTORE_DRILL_SKIP=true             # skip quarterly restore drill verification
# ATLAS_DNS_SERVERS=8.8.8.8,1.1.1.1
# ATLAS_BACKUP_PHASE=deferred

# Phase 2 — weekly mongodump to Cloudflare R2 (npm run backup:mongodump:dry-run)
# CLOUDFLARE_ACCOUNT_ID=          # R2 overview → Account ID
# CLOUDFLARE_API_TOKEN=           # Create R2 bucket via npm run setup:mongo-backup-rollout --r2
# BACKUP_S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# BACKUP_S3_BUCKET=ops-dashboard-mongo-backups
# BACKUP_S3_ACCESS_KEY=           # R2 → Manage R2 API Tokens → Object Read and Write
# BACKUP_S3_SECRET_KEY=
# BACKUP_S3_REGION=auto
# BACKUP_S3_PREFIX=ops-dashboard
# BACKUP_RETAIN_DAYS=7

JWT_SECRET=
JWT_EXPIRES_IN=7d
# Session: admin setting sessionTimeoutMinutes=0 keeps users signed in until logout (10y JWT/cookie).
# Optional override for all tenants without DB change:
# FORCE_PERSISTENT_SESSION=true
# PERSISTENT_SESSION_MAX_AGE_MS=315360000000

# Expo push (mobile background alerts). Optional — without it, in-app Socket notifications still work.
# Create a token at: Expo dashboard → Access tokens (or https://expo.dev/accounts/<account>/settings/access-tokens)
# EXPO_ACCESS_TOKEN=

# Web Push (browser desktop notifications). Optional — generate keys: npx web-push generate-vapid-keys
# Same public key must be set on the frontend as VITE_WEB_PUSH_PUBLIC_KEY (Vercel / .env.production).
# WEB_PUSH_PUBLIC_KEY=
# WEB_PUSH_PRIVATE_KEY=
# WEB_PUSH_SUBJECT=mailto:support@yourdomain.com

METAL_RATES_BRIDGE_TOKEN=
# METAL_RATES_BRIDGE_FANOUT_TENANTS=all
# Mark MT4 feed stale if no bridge post within this window (ms). Default 30000.
# MT4_LIVE_STALE_MS=30000
COOKIE_MAX_AGE_MS=604800000
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173,http://mg.localhost:5173,http://cg.localhost:5173,http://loopc.localhost:5173
SERVER_BASE_URL=http://localhost:5000
REQUEST_BODY_LIMIT=5mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1200
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=50

# Jest only: skip MongoDB Memory Server (embedded mongod) and use this URI for integration tests.
# Handy on Windows without VC++ redist — run MongoDB locally or: docker run -d -p 27017:27017 mongo:7
# MONGO_TEST_URI=mongodb://127.0.0.1:27017/ops_dashboard_jest

# MG destructive reset (danger-reset-mg-transactions.js) — never commit real values
# MG_DESTRUCTIVE_CONFIRM_TOKEN=
# ALLOW_MG_DESTRUCTIVE_RESET=false

# Versioned DB migrations (backend/migrations/runner.js)
# MIGRATION_CONFIRM_TOKEN=
# JV live audit: npm run verify:jv-live -- --tenant all (or verify:mg-jv-live for MG only)
# JV live roundtrip: npm run test:jv-live-roundtrip (dry-run) / test:jv-live-roundtrip:apply
# Local bootstrap passwords — set in your private .env only; never commit real values
# MG_ADMIN_PASSWORD=
# MG_ADMIN_NAME=Nan
# CG_ADMIN_PASSWORD=
# CG_ADMIN_NAME=
# LOOPC_ADMIN_PASSWORD=
# LOOPC_ADMIN_NAME=

ENABLE_DESTRUCTIVE_ADMIN_API=false
ENABLE_PERMANENT_DELETE_API=false
ENABLE_ADMIN_CLEANUP_API=false
DESTRUCTIVE_ADMIN_CONFIRM_TOKEN=
CLEANUP_CONFIRM_TOKEN=
ALLOW_PRODUCTION_DESTRUCTIVE_SCRIPT=false

# Live spot prices for ERP dashboard (gold / silver / platinum / palladium, USD per troy oz).
# Sign up at https://metals.dev → copy API key → paste below. Required for live feed when using default provider.
METALS_DEV_API_KEY=
# Optional: legacy alias
# METALS_API_KEY=
# Optional tuning (see ENV-VARS-QUICK-REFERENCE.md). Lower = fresher prices but more metals.dev API calls (watch free-tier limits).
# METALS_SPOT_CACHE_MS=1500
# METALS_SPOT_SSE_POLL_MS=1000
# METALS_MARKET_URL=https://api.metals.dev/v1/latest
# Fallback live feeds if metals.dev fails or hits quota (backend tries FRED, then Alpha Vantage):
# FRED_API_KEY=
# FRED_METALS_SERIES_SILVER=
# ALPHA_VANTAGE_API_KEY=
# METALS_ALPHA_VANTAGE_API_KEY=
# Synthetic USD/toz ticks for real-time UI testing (skips real APIs; off in production unless ALLOW_PRODUCTION set):
# METALS_SPOT_MOCK_REALTIME=true
# METALS_SPOT_MOCK_REALTIME_ALLOW_PRODUCTION=true

# ERP smoke test overrides (optional)
SMOKE_API_BASE_URL=http://localhost:5000
SMOKE_LOGIN_COMPANY=loopc
SMOKE_DEFAULT_NAME=Nan
SMOKE_DEFAULT_PASSWORD=
SMOKE_LOGIN_NAME=Nan
SMOKE_LOGIN_PASSWORD=
SMOKE_LEDGER_DEPARTMENT=sales
SMOKE_LEDGER_REFERENCE_TYPE=invoice
SMOKE_LEDGER_LIMIT=5

# Operations projects — optional background jobs & integrations
# TASK_REMINDER_JOB=false          # set false to disable 60s reminder sweep (default on)
# TASK_STALE_COMMENT_JOB=true     # nightly-style interval: append system "stale" comment (default off)
# TASK_STALE_COMMENT_INTERVAL_MS=86400000
# TASK_STALE_MS=604800000         # inactivity threshold before stale (default 7 days). Align frontend: VITE_OPS_PROJECTS_STALE_DAYS (or VITE_TASK_STALE_DAYS) × 86400000
# TASK_STALE_COMMENT_TEXT=        # optional override for the system comment body
# TASK_WEBHOOK_ENABLED=true       # required to POST outbound task webhooks (default off even if URLs are set)
# TASK_WEBHOOK_URLS=https://example.com/hook1,https://example.com/hook2
# TASK_WEBHOOK_SECRET=            # optional HMAC secret → X-Task-Signature header (body includes webhookDeliveryId per delivery)

# Sales Manager AI (LoopC only — Tavily web research + OpenAI synthesis)
SALES_AI_ALLOWED_TENANTS=loopc
# OPENAI_API_KEY=
# OPENAI_SALES_AI_MODEL=gpt-4o-mini
# TAVILY_API_KEY=
# SALES_AI_CHAT_RATE_LIMIT_MAX=20
# SALES_AI_MAX_TAVILY_SEARCHES=4
# SALES_AI_TAVILY_INCLUDE_ANSWER=true
# SALES_AI_SYNTHESIS_MODE=auto
# auto = try OpenAI, fall back to template on quota/missing key
# template = Tavily + CRM report only ($0 OpenAI)
# openai = require OpenAI (fails if quota/missing)

# Sales Manager AI — company Gmail inbox (see docs/SALES-AI-EMAIL.md)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Or download OAuth JSON from Google Cloud → backend/.google-oauth-client.json (gitignored)
# EMAIL_TOKEN_ENCRYPTION_KEY=   # 64-char hex — npm run setup:gmail-railway generates + pushes to Railway
# GOOGLE_OAUTH_TENANT_REDIRECT_URI=https://api.loopcstrategies.com/api/email/oauth/gmail/tenant/callback
# API_PUBLIC_URL=https://api.loopcstrategies.com

# Task rules (auto-archive after Done; due-soon notifications) — background job, default off; set true to opt in
# TASK_RULES_JOB=true
# TASK_RULES_INTERVAL_MS=600000
# TASK_RULE_AUTO_ARCHIVE_MS=604800000
# TASK_DUE_PROXIMITY_HOURS=48

# Chat attachments (local disk storage)
# CHAT_UPLOAD_DIR=uploads/chat
# CHAT_ATTACHMENT_MAX_BYTES=15728640
