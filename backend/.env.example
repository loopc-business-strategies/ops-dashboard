PORT=5000
# Option 1: provide full MongoDB URI
MONGO_URI=

# Option 2: Atlas parts (used if MONGO_URI is empty)
DB_USER=
DB_PASS=
DB_CLUSTER=cluster0.term9x.mongodb.net
DB_NAME=ops-dashboard
DB_PARAMS=retryWrites=true&w=majority

JWT_SECRET=change_this_to_a_strong_random_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173,http://mg.localhost:5173,http://cg.localhost:5173,http://loopc.localhost:5173

# ERP smoke test overrides (optional)
SMOKE_API_BASE_URL=http://localhost:5000
SMOKE_LOGIN_NAME=AdminUser
SMOKE_LOGIN_PASSWORD=admin123
SMOKE_LEDGER_DEPARTMENT=sales
SMOKE_LEDGER_REFERENCE_TYPE=invoice
SMOKE_LEDGER_LIMIT=5
