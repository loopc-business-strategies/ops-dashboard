PORT=5000
DB_NAME=ops-dashboard
DEFAULT_TENANT=loopc

# Required tenant database URIs. Each tenant should point at its own MongoDB database/cluster.
MONGO_URI_MG=
MONGO_URI_CG=
MONGO_URI_LOOPC=

JWT_SECRET=change_this_to_a_strong_random_secret
JWT_EXPIRES_IN=7d
METAL_RATES_BRIDGE_TOKEN=change-this-long-random-token
COOKIE_MAX_AGE_MS=604800000
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173,http://mg.localhost:5173,http://cg.localhost:5173,http://loopc.localhost:5173
SERVER_BASE_URL=http://localhost:5000
REQUEST_BODY_LIMIT=100kb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=400
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=25

# Destructive admin APIs/scripts are disabled unless explicitly configured.
ENABLE_DESTRUCTIVE_ADMIN_API=false
ENABLE_PERMANENT_DELETE_API=false
DESTRUCTIVE_ADMIN_CONFIRM_TOKEN=
CLEANUP_CONFIRM_TOKEN=
ALLOW_PRODUCTION_DESTRUCTIVE_SCRIPT=false

# Live spot prices for ERP dashboard (gold / silver / platinum / palladium, USD per troy oz).
# Sign up at https://metals.dev → copy API key → paste below. Required for live feed when using default provider.
METALS_DEV_API_KEY=
# Optional: legacy alias
# METALS_API_KEY=
# Optional tuning (see ENV-VARS-QUICK-REFERENCE.md). Lower = fresher prices but more metals.dev API calls (watch free-tier limits).
# METALS_SPOT_CACHE_MS=1500
# METALS_SPOT_SSE_POLL_MS=1000
# METALS_MARKET_URL=https://api.metals.dev/v1/latest
# Fallback live feeds if metals.dev fails or hits quota (backend tries FRED, then Alpha Vantage):
# FRED_API_KEY=
# FRED_METALS_SERIES_SILVER=
# ALPHA_VANTAGE_API_KEY=
# METALS_ALPHA_VANTAGE_API_KEY=
# Synthetic USD/toz ticks for real-time UI testing (skips real APIs; off in production unless ALLOW_PRODUCTION set):
# METALS_SPOT_MOCK_REALTIME=true
# METALS_SPOT_MOCK_REALTIME_ALLOW_PRODUCTION=true

# ERP smoke test overrides (optional)
SMOKE_API_BASE_URL=http://localhost:5000
SMOKE_LOGIN_COMPANY=loopc
SMOKE_DEFAULT_NAME=Nan
SMOKE_DEFAULT_PASSWORD=
SMOKE_LOGIN_NAME=Nan
SMOKE_LOGIN_PASSWORD=
SMOKE_LEDGER_DEPARTMENT=sales
SMOKE_LEDGER_REFERENCE_TYPE=invoice
SMOKE_LEDGER_LIMIT=5
