# Local staging provisioning ONLY — copy to backend/.env.staging.local
# Never put production MONGO_URI_* values in this file.

STAGING_MONGO_URI_MG=mongodb+srv://<user>:<pass>@<staging-mg-cluster>/<db>
STAGING_MONGO_URI_CG=mongodb+srv://<user>:<pass>@<staging-cg-cluster>/<db>
STAGING_MONGO_URI_LOOPC=mongodb+srv://<user>:<pass>@<staging-loopc-cluster>/<db>

STAGING_SMOKE_API_BASE=https://ops-dashboard-staging-e6c6.up.railway.app

# Optional — reuse password from setup-staging-env generated file
# STAGING_SMOKE_AUTH_PASSWORD=
