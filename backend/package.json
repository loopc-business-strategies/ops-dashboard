{
  "name": "ops-dashboard-backend",
  "version": "1.0.0",
  "packageManager": "npm@10.8.2",
  "main": "server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "reset:nan:all-tenants": "node scripts/destructive/reset-nan-all-tenants.js",
    "seed:erp": "node scripts/destructive/seed-erp-accounting.js",
    "reset:erp:start": "node scripts/destructive/reset-erp-start.js",
    "reset:erp:master": "node scripts/destructive/reset-erp-master-fresh.js",
    "bootstrap:statutory": "node scripts/bootstrap-statutory-accounts-all-tenants.js",
    "prune:customer-accounts": "node scripts/destructive/prune-customer-accounts.js",
    "migrate:mapping-departments": "node scripts/backfill-mapping-departments.js",
    "smoke:erp": "node scripts/smoke-erp-api.js",
    "test": "jest --runInBand",
    "test:fast": "jest --runInBand tests/permissions.test.js",
    "test:pagination": "jest --runInBand tests/pagination-edge-cases.test.js",
    "test:integration": "npm run test:integration:tenant-routing && npm run test:integration:tenant-isolation && npm run test:integration:erp",
    "test:integration:tenant-routing": "jest --runInBand --testTimeout=120000 tests/tenant-routing-auth.test.js",
    "test:integration:tenant-isolation": "jest --runInBand --testTimeout=120000 tests/tenant-db-isolation.test.js",
    "test:integration:erp": "jest --runInBand --testTimeout=120000 tests/erp-accounting-transactions.test.js",
    "test:watch": "jest --watch",
    "cleanup:safe": "node scripts/safe-cleanup-cli.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.2",
    "mongo-sanitize": "^1.1.0",
    "mongoose": "^9.6.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "socket.io": "^4.8.3",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.1.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.1.4"
  }
}
