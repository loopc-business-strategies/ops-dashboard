{
  "name": "ops-dashboard-backend",
  "version": "1.0.0",
  "main": "server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "reset:nan:all-tenants": "node scripts/reset-nan-all-tenants.js",
    "seed:erp": "node scripts/seed-erp-accounting.js",
    "reset:erp:start": "node scripts/reset-erp-start.js",
    "reset:erp:master": "node scripts/reset-erp-master-fresh.js",
    "bootstrap:statutory": "node scripts/bootstrap-statutory-accounts-all-tenants.js",
    "prune:customer-accounts": "node scripts/prune-customer-accounts.js",
    "migrate:mapping-departments": "node scripts/backfill-mapping-departments.js",
    "smoke:erp": "node scripts/smoke-erp-api.js",
    "test": "jest --runInBand",
    "test:fast": "jest --runInBand tests/permissions.test.js",
    "test:integration": "jest --runInBand --testTimeout=120000 tests/erp-accounting-transactions.test.js",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mongo-sanitize": "^1.1.0",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "mongodb-memory-server": "^10.2.3",
    "nodemon": "^3.0.2",
    "supertest": "^7.1.4"
  }
