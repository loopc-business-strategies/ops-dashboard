# Production Environment Variables for Railway
# Copy this file to Railway as environment variables

# Server Settings
NODE_ENV=production
PORT=5000

# JWT & Security
JWT_SECRET=<generate-a-random-32-char-string-with-node>
JWT_EXPIRES_IN=7d
COOKIE_MAX_AGE_MS=604800000

# Default Tenant
DEFAULT_TENANT=loopc

# MongoDB Connection Strings - MG Cluster
MONGO_URI_MG=mongodb+srv://<mg-user>:<mg-password>@<mg-cluster>/<database>?retryWrites=true&w=majority

# MongoDB Connection Strings - CG Cluster
MONGO_URI_CG=mongodb+srv://<cg-user>:<cg-password>@<cg-cluster>/<database>?retryWrites=true&w=majority

# MongoDB Connection Strings - LoopC Cluster
MONGO_URI_LOOPC=mongodb+srv://<loopc-user>:<loopc-password>@<loopc-cluster>/<database>?retryWrites=true&w=majority

# Shared coordination (recommended for multi-instance Railway)
# REDIS_URL=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1200
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=25
REQUEST_BODY_LIMIT=5mb

# CORS & Client URLs (set after Vercel domains are configured)
CLIENT_URL=https://mg.yourdomain.com,https://cg.yourdomain.com,https://loopc.yourdomain.com,https://app.yourdomain.com,http://mg.localhost:5173,http://cg.localhost:5173,http://loopc.localhost:5173

# Logging
LOG_LEVEL=info

# Security tokens (generate unique production values — never commit real secrets)
# SETUP_TOKEN=
# CLEANUP_CONFIRM_TOKEN=
# DESTRUCTIVE_ADMIN_CONFIRM_TOKEN=
# MG_DESTRUCTIVE_CONFIRM_TOKEN=
# MIGRATION_CONFIRM_TOKEN=
# ENABLE_SETUP=false
# ENABLE_ADMIN_CLEANUP_API=false
# ENABLE_DESTRUCTIVE_ADMIN_API=false

# Migrations — dry-run default; apply only after backup + MIGRATION_I_HAVE_BACKUP=true
# ALLOW_PRODUCTION_MIGRATION=false

# --- Live ERP spot metals (dashboard widget + SSE stream) ---
# Get a key at https://metals.dev and add to Railway Variables as METALS_DEV_API_KEY
METALS_DEV_API_KEY=<your-metals-dev-api-key>
# Optional: only if you proxy metals.dev yourself
# METALS_MARKET_URL=https://api.metals.dev/v1/latest
# METALS_SPOT_CACHE_MS=2200
# METALS_SPOT_SSE_POLL_MS=900
