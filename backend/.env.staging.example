# Staging backend environment template (Railway)
# Copy variable NAMES to your staging service — use STAGING MongoDB URIs only.
# Never point staging at production MONGO_URI_* values.

NODE_ENV=production
PORT=5000
DEFAULT_TENANT=loopc

# Staging-only JWT (different from production)
JWT_SECRET=<generate-staging-only-secret>

# Separate staging Atlas clusters / databases — NOT production URIs
MONGO_URI_MG=mongodb+srv://<user>:<pass>@<staging-mg-cluster>/<db>
MONGO_URI_CG=mongodb+srv://<user>:<pass>@<staging-cg-cluster>/<db>
MONGO_URI_LOOPC=mongodb+srv://<user>:<pass>@<staging-loopc-cluster>/<db>

ALLOW_TENANT_LEGACY_FALLBACK=false
ALLOW_SERVER_LEGACY_FALLBACK=false

# Security tokens (generate unique values per environment)
SETUP_TOKEN=<staging-setup-token-if-needed>
CLEANUP_CONFIRM_TOKEN=<staging-cleanup-token>
DESTRUCTIVE_ADMIN_CONFIRM_TOKEN=<staging-destructive-token>
# MG destructive script only — never reuse production value
# MG_DESTRUCTIVE_CONFIRM_TOKEN=

# Migrations — dry-run by default; apply only on staging after backup
# MIGRATION_CONFIRM_TOKEN=
# MIGRATION_I_HAVE_BACKUP=false
# ALLOW_PRODUCTION_MIGRATION=false

ENABLE_SETUP=false
ENABLE_ADMIN_CLEANUP_API=false
ENABLE_DESTRUCTIVE_ADMIN_API=false

CLIENT_URLS=https://<staging-preview-host>.vercel.app
SERVER_BASE_URL=https://<staging-api-host>
REQUEST_BODY_LIMIT=5mb

SENTRY_ENVIRONMENT=staging
