{
  "installCommand": "cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "experimentalServices": {
    "frontend": {
      "mount": "/",
      "builder": "@vercel/static-build",
      "entrypoint": "frontend/package.json"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "has": [
        { "type": "host", "value": "(mg|cg|loopc|app)\\.loopcstrategies\\.com" }
      ],
      "destination": "https://api.loopcstrategies.com/api/$1"
    },
    {
      "source": "/api/(.*)",
      "has": [
        { "type": "host", "value": ".*\\.vercel\\.app" }
      ],
      "destination": "/api-preview-disabled.json"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
