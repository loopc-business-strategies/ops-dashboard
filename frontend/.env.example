# Frontend env (copy to .env.local — do not commit secrets)
# Full reference: ../ENV-VARS-QUICK-REFERENCE.md

# API base — leave unset on Vercel for same-origin /api rewrite (recommended)
# VITE_API_URL=
# VITE_API_BASE_URL=
# VITE_API_TIMEOUT_MS=

# Web Push public key — same value as backend WEB_PUSH_PUBLIC_KEY
# VITE_WEB_PUSH_PUBLIC_KEY=

# Sentry browser errors — see docs/OBSERVABILITY-SENTRY.md
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=development
# VITE_SENTRY_RELEASE=
# VITE_SENTRY_TRACES_SAMPLE_RATE=0

# Operations projects stale badge (days) — align with backend TASK_STALE_MS
# VITE_OPS_PROJECTS_STALE_DAYS=7
# VITE_TASK_STALE_DAYS=7

# Dev-only demo seed data in tabs
# VITE_ENABLE_SEED_DATA=false

# Build metadata (usually set by CI)
# VITE_BUILD_SHA=
# VITE_BUILD_TIME=
