# Nexa mobile — copy to mobile/.env for local dev / custom builds.
# Full reference: ../ENV-VARS-QUICK-REFERENCE.md

# API base (include /api suffix if your deployment uses it on the host path)
EXPO_PUBLIC_API_URL=https://api.loopcstrategies.com

# Optional — override committed EAS project id for forked builds
# EXPO_PUBLIC_EAS_PROJECT_ID=

# Sentry mobile errors — see docs/OBSERVABILITY-SENTRY.md
# EXPO_PUBLIC_SENTRY_DSN=
# EXPO_PUBLIC_SENTRY_ENVIRONMENT=development
# EXPO_PUBLIC_SENTRY_RELEASE=
# EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
