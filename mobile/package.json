{
  "name": "mg-ops-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "expo": "~56.0.8",
    "expo-constants": "~56.0.16",
    "expo-font": "~56.0.5",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.8",
    "expo-secure-store": "^56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-updates": "~56.0.17",
    "expo-web-browser": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "eas-cli": "^20.0.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:preview:android": "eas build --platform android --profile preview --non-interactive",
    "build:preview:ios": "eas build --platform ios --profile preview --non-interactive",
    "build:production:android": "eas build --platform android --profile production --non-interactive",
    "build:production:ios": "eas build --platform ios --profile production --non-interactive",
    "update:preview": "eas update --channel preview --non-interactive",
    "update:production": "eas update --channel production --non-interactive",
    "submit:android": "eas submit --platform android --profile production --latest --non-interactive",
    "submit:ios": "eas submit --platform ios --profile production --latest --non-interactive"
  },
  "private": true
}
