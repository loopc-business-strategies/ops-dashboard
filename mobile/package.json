{
  "name": "nexa",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@microsoft/fetch-event-source": "^2.0.1",
    "@react-native-community/datetimepicker": "9.1.0",
    "@sentry/react-native": "~7.11.0",
    "expo": "~56.0.8",
    "expo-constants": "~56.0.16",
    "expo-document-picker": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-image-picker": "~56.0.18",
    "expo-linking": "~56.0.14",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-secure-store": "^56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-updates": "~56.0.19",
    "expo-web-browser": "~56.0.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.86.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "^15.15.5",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.17",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "check": "npm run typecheck && npm run test",
    "check:release": "node ./scripts/check-release-readiness.mjs",
    "smoke:api": "node ./scripts/smoke-mobile-api.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild:android": "expo prebuild --platform android",
    "build:local:android:bundle": "node ./scripts/gradle-android.mjs bundleRelease",
    "build:local:android:apk": "node ./scripts/gradle-android.mjs assembleRelease",
    "build:preview:android": "npx eas-cli build --platform android --profile preview --non-interactive",
    "build:preview:ios": "npx eas-cli build --platform ios --profile preview --non-interactive",
    "build:preview:ios-simulator": "npx eas-cli build --platform ios --profile preview-simulator --non-interactive",
    "build:production:android": "npx eas-cli build --platform android --profile production --non-interactive",
    "build:production:ios": "npx eas-cli build --platform ios --profile production --non-interactive",
    "update:preview": "npx eas-cli update --channel preview --environment preview --message \"Nexa preview update\" --non-interactive",
    "update:production": "npx eas-cli update --channel production --environment production --message \"Nexa production update\" --non-interactive",
    "submit:android": "npx eas-cli submit --platform android --profile production --latest --non-interactive",
    "submit:ios": "npx eas-cli submit --platform ios --profile production --latest --non-interactive"
  },
  "private": true
}
