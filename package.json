{
  "name": "ops-dashboard-workspace",
  "packageManager": "npm@10.8.2",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/dev-orchestrator.js",
    "dev:legacy": "concurrently \"npm --prefix backend run dev\" \"npm --prefix frontend run dev\"",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:mobile": "npm --prefix mobile run start",
    "mobile:build:android:preview": "npm --prefix mobile run build:preview:android",
    "mobile:build:ios:preview": "npm --prefix mobile run build:preview:ios",
    "mobile:build:android": "npm --prefix mobile run build:production:android",
    "mobile:build:ios": "npm --prefix mobile run build:production:ios",
    "typecheck:mobile": "npm --prefix mobile run typecheck",
    "test:mobile": "npm --prefix mobile run test",
    "mobile:update:preview": "npm --prefix mobile run update:preview",
    "mobile:update:production": "npm --prefix mobile run update:production",
    "lint": "npm run check:tracked-paths && npm run check:destructive-guards && npm run check:risk-guardrails && npm run check:vercel-rewrites && npm run lint:eslint:ci && npm run lint:eslint:hooks-order && npm run lint:eslint:finance-ops && npm run lint:eslint:extended-tabs && npm run lint:eslint:erp-shell-tabs",
    "lint:eslint": "eslint frontend/src",
    "lint:eslint:ci": "node ./node_modules/eslint/bin/eslint.js \"frontend/src/components/tabs/erp/**/*.js\" \"frontend/src/components/tabs/erp/**/*.jsx\" \"frontend/src/api/**/*.js\" --ignore-pattern \"**/*.test.js\" --ignore-pattern \"**/*.test.jsx\" --ignore-pattern \"**/*.node.test.js\" --ignore-pattern \"**/*.contract.test.js\" --ignore-pattern \"**/*.contract.test.jsx\" --max-warnings=0",
    "lint:eslint:hooks-order": "node scripts/check-eslint-react-hooks-order.mjs",
    "lint:eslint:finance-ops": "node ./node_modules/eslint/bin/eslint.js \"frontend/src/components/tabs/FinanceTab.jsx\" \"frontend/src/components/tabs/OperationsTab.jsx\" --max-warnings=0",
    "lint:eslint:extended-tabs": "node ./node_modules/eslint/bin/eslint.js \"frontend/src/__tests__/smoke.test.jsx\" \"frontend/src/components/BuildInfoBadge.jsx\" \"frontend/src/components/tabs/AdminTab.jsx\" \"frontend/src/components/tabs/ChartOfAccountsTree.jsx\" \"frontend/src/components/tabs/ChatTab.jsx\" \"frontend/src/components/tabs/ComplianceTab.jsx\" \"frontend/src/components/tabs/DirectDealsTab.jsx\" \"frontend/src/components/tabs/HRTab.jsx\" \"frontend/src/components/tabs/OverviewTab.jsx\" \"frontend/src/components/tabs/ProductionTab.jsx\" \"frontend/src/context/LiveMetalRatesContext.jsx\" \"frontend/src/utils/liveMetalRates.js\" --max-warnings=0",
    "lint:eslint:erp-shell-tabs": "node ./node_modules/eslint/bin/eslint.js \"frontend/src/components/tabs/ERPTab.jsx\" \"frontend/src/components/tabs/VoucherTab.jsx\" --max-warnings=0",
    "check:ci-parity": "npm run lint && npm run typecheck:mobile && npm run sync:erp-access && npm --prefix backend run test:fast",
    "lint:eslint:repo": "node ./node_modules/eslint/bin/eslint.js frontend/src",
    "check:tracked-paths": "node scripts/check-forbidden-tracked-paths.mjs",
    "check:dependency-audit": "node scripts/run-production-dependency-audit.mjs",
    "check:dependency-audit:advisory": "node scripts/run-production-dependency-audit.mjs --advisory",
    "check:destructive-guards": "node scripts/check-destructive-script-guards.mjs",
    "check:frontend-bundle": "node scripts/check-frontend-bundle-budget.mjs",
    "check:risk-guardrails": "node scripts/check-risk-guardrails.mjs",
    "check:vercel-rewrites": "node scripts/check-vercel-rewrites.mjs",
    "sync:erp-access": "node scripts/sync-erp-access-policy.js",
    "smoke:tenants": "node scripts/smoke-tenants.js",
    "smoke:prod": "node scripts/production-smoke.js",
    "smoke:setup-secrets": "node scripts/setup-smoke-github-secrets.js",
    "load:smoke": "node scripts/http-load-smoke.mjs",
    "test:e2e": "npm --prefix frontend run test:e2e",
    "test:backend": "npm run check:tracked-paths && npm run check:destructive-guards && npm run check:risk-guardrails && npm run check:vercel-rewrites && npm run sync:erp-access && npm --prefix backend test",
    "test:frontend": "npm run check:tracked-paths && npm run check:destructive-guards && npm run check:risk-guardrails && npm run check:vercel-rewrites && npm run sync:erp-access && npm --prefix frontend test && npm --prefix frontend run test:unit",
    "build:backend": "npm run sync:erp-access && cd backend && npm install --omit=dev",
    "build:frontend": "npm run sync:erp-access && cd frontend && npm run build && cd .. && npm run check:frontend-bundle",
    "deploy:railway": "npm run test:backend && npm run test:frontend && echo '✓ All tests passed. Ready for Railway deployment.'",
    "cleanup:safe": "npm --prefix backend run cleanup:safe"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/preset-react": "^7.28.5",
    "@eslint/js": "^9.15.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0"
  }
}
