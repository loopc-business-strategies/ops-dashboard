{
  "name": "ops-dashboard-workspace",
  "packageManager": "npm@10.8.2",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "node scripts/dev-orchestrator.js",
    "dev:legacy": "concurrently \"npm --prefix backend run dev\" \"npm --prefix frontend run dev\"",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:mobile": "npm --prefix mobile run start",
    "mobile:build:android:local:bundle": "npm --prefix mobile run build:local:android:bundle",
    "mobile:build:android:local:apk": "npm --prefix mobile run build:local:android:apk",
    "mobile:ios:github": "echo Run GitHub Actions workflow Mobile iOS (GitHub macOS) — see docs/MOBILE-IOS-GITHUB-BUILD.md",
    "mobile:prebuild:android": "npm --prefix mobile run prebuild:android",
    "mobile:build:android:preview": "npm --prefix mobile run build:preview:android",
    "mobile:build:ios:preview": "npm --prefix mobile run build:preview:ios",
    "mobile:build:android": "npm --prefix mobile run build:production:android",
    "mobile:build:ios": "npm --prefix mobile run build:production:ios",
    "typecheck:mobile": "npm --prefix mobile run typecheck",
    "test:mobile": "npm --prefix mobile run test",
    "check:mobile": "npm --prefix mobile run check",
    "smoke:mobile:api": "npm --prefix mobile run smoke:api",
    "smoke:mobile:staging": "node scripts/run-mobile-staging-smoke.mjs",
    "check:tenant-branding-parity": "node scripts/check-tenant-branding-parity.mjs",
    "check:locale-parity": "node scripts/check-locale-parity.mjs",
    "check:atlas-strict-readiness": "node scripts/check-atlas-strict-readiness.mjs",
    "setup:staging": "node scripts/setup-staging-env.mjs",
    "setup:staging:railway": "node scripts/apply-staging-railway-vars.mjs",
    "setup:staging:mongo-local": "node scripts/sync-staging-mongo-local.mjs",
    "setup:staging:github": "node scripts/setup-staging-env.mjs --push-github",
    "setup:staging:check": "node scripts/setup-staging-env.mjs --check-github",
    "verify:mg-jv-live": "node scripts/run-mg-jv-live-verify.mjs",
    "verify:mg-jv-live:smoke": "node scripts/run-mg-jv-live-verify.mjs --smoke-only",
    "verify:jv-live": "node scripts/run-jv-live-verify.mjs",
    "verify:jv-live:smoke": "node scripts/run-jv-live-verify.mjs --smoke-only",
    "test:jv-live-roundtrip": "node scripts/jv-live-roundtrip.mjs --tenant all",
    "test:jv-live-roundtrip:apply": "node scripts/jv-live-roundtrip.mjs --tenant all --apply",
    "migrate:fx-journal-to-expense": "node scripts/migrate-fx-adjustment-journal-to-expense.mjs --tenant all",
    "migrate:fx-journal-to-expense:apply": "node scripts/migrate-fx-adjustment-journal-to-expense.mjs --tenant all --apply",
    "migrate:dry": "npm --prefix backend run migrate",
    "migrate:staging": "node scripts/migrate-staging.mjs --until=002-backfill-mapping-departments",
    "migrate:staging:apply": "node scripts/migrate-staging.mjs --until=002-backfill-mapping-departments --apply",
    "migrate:staging:003:dry": "node scripts/migrate-staging.mjs --until=003-backfill-jv-ledger-base-to-fc",
    "migrate:staging:003:apply": "node scripts/migrate-staging.mjs --until=003-backfill-jv-ledger-base-to-fc --apply",
    "verify:live-metal-movement": "node scripts/verify-live-metal-movement.mjs --tenant mg",
    "verify:live-metal-movement:all": "node scripts/verify-live-metal-movement.mjs --tenant all",
    "verify:critical-health": "node scripts/verify-critical-health.mjs",
    "verify:backup-checklist": "node scripts/verify-backup-checklist.mjs",
    "verify:mongo-backup-drill": "node scripts/verify-mongo-backup-drill.mjs",
    "verify:atlas-backup-drill": "node scripts/verify-atlas-backup-drill.mjs",
    "drill:atlas-backup-plan": "node scripts/run-atlas-backup-drill-plan.mjs",
    "backup:mongodump": "node scripts/mongodump-tenants.mjs",
    "backup:mongodump:dry-run": "node scripts/mongodump-tenants.mjs --dry-run",
    "setup:mongo-backup-rollout": "node scripts/setup-mongo-backup-rollout.mjs --all",
    "setup:mongo-backup-rollout:check": "node scripts/setup-mongo-backup-rollout.mjs --check",
    "atlas:strict-phase-checklist": "node scripts/print-atlas-strict-phase.mjs",
    "verify:upload-storage": "node scripts/verify-upload-storage.mjs",
    "verify:data-safety": "npm run verify:upload-storage && npm run verify:mongo-backup-drill",
    "mobile:release:android": "node scripts/trigger-mobile-release.mjs android",
    "mobile:download:apk": "node scripts/download-mobile-apk.mjs",
    "mobile:install:apk": "node scripts/install-mobile-apk.mjs",
    "mobile:release:ios": "node scripts/trigger-mobile-release.mjs ios",
    "mobile:update:preview": "npm --prefix mobile run update:preview",
    "mobile:update:production": "npm --prefix mobile run update:production",
    "lint": "npm run check:tracked-paths && npm run check:destructive-guards && npm run check:erp-legacy-imports && npm run check:risk-guardrails && npm run check:vercel-rewrites && npm run lint:eslint:ci && npm run lint:eslint:hooks-order && npm run lint:eslint:finance-ops && npm run lint:eslint:extended-tabs && npm run lint:eslint:erp-shell-tabs && npm run lint:eslint:backend && npm run lint:eslint:repo",
    "lint:eslint": "eslint frontend/src",
    "lint:eslint:ci": "node ./node_modules/eslint/bin/eslint.js \"frontend/src/components/tabs/erp/**/*.js\" \"frontend/src/components/tabs/erp/**/*.jsx\" \"frontend/src/api/**/*.js\" --ignore-pattern \"**/*.test.js\" --ignore-pattern \"**/*.test.jsx\" --ignore-pattern \"**/*.node.test.js\" --ignore-pattern \"**/*.contract.test.js\" --ignore-pattern \"**/*.contract.test.jsx\" --max-warnings=0",
    "lint:eslint:hooks-order": "node scripts/check-eslint-react-hooks-order.mjs",
    "lint:eslint:finance-ops": "node ./node_modules/eslint/bin/eslint.js \"frontend/src/components/tabs/FinanceTab.jsx\" \"frontend/src/components/tabs/OperationsTab.jsx\" --max-warnings=0",
    "lint:eslint:extended-tabs": "node ./node_modules/eslint/bin/eslint.js \"frontend/src/__tests__/smoke.test.jsx\" \"frontend/src/components/BuildInfoBadge.jsx\" \"frontend/src/components/tabs/AdminTab.jsx\" \"frontend/src/components/tabs/ChartOfAccountsTree.jsx\" \"frontend/src/components/tabs/ChatTab.jsx\" \"frontend/src/components/tabs/ComplianceTab.jsx\" \"frontend/src/components/tabs/DirectDealsTab.jsx\" \"frontend/src/components/tabs/HRTab.jsx\" \"frontend/src/components/tabs/OverviewTab.jsx\" \"frontend/src/components/tabs/ProductionTab.jsx\" \"frontend/src/context/LiveMetalRatesContext.jsx\" \"frontend/src/utils/liveMetalRates.js\" --max-warnings=0",
    "lint:eslint:erp-shell-tabs": "node ./node_modules/eslint/bin/eslint.js \"frontend/src/components/tabs/ERPTab.jsx\" \"frontend/src/components/tabs/VoucherTab.jsx\" \"frontend/src/components/tabs/voucher/**/*.jsx\" \"frontend/src/components/tabs/erp/accountEnquiry/**/*.jsx\" --max-warnings=0",
    "lint:eslint:backend": "node ./node_modules/eslint/bin/eslint.js --max-warnings=0 \"backend/app.js\" \"backend/server.js\" \"backend/middleware/**/*.js\" \"backend/routes/**/*.js\" \"backend/utils/**/*.js\" \"backend/services/**/*.js\" \"backend/models/**/*.js\" \"backend/config/**/*.js\" \"backend/db/**/*.js\" \"backend/realtime/**/*.js\" \"backend/jobs/**/*.js\"",
    "check:ci-parity": "npm run lint && npm run check:tenant-branding-parity && npm run check:locale-parity && npm run check:atlas-strict-readiness && npm run typecheck:mobile && npm run test:mobile && npm --prefix mobile run check:release && node scripts/check-erp-access-git-clean.mjs && npm --prefix backend run test:fast && npm --prefix backend run test:coverage && npm --prefix backend run test:erp-accounting && npm --prefix frontend test && npm --prefix frontend run test:unit",
    "check:ci-parity:full": "npm run check:ci-parity && npm run test:backend && npm run test:frontend",
    "lint:eslint:repo": "node ./node_modules/eslint/bin/eslint.js frontend/src --max-warnings=0",
    "check:tracked-paths": "node scripts/check-forbidden-tracked-paths.mjs",
    "check:dependency-audit": "node scripts/run-production-dependency-audit.mjs",
    "check:dependency-audit:advisory": "node scripts/run-production-dependency-audit.mjs --advisory",
    "check:destructive-guards": "node scripts/check-destructive-script-guards.mjs",
    "check:erp-legacy-imports": "node scripts/check-erp-legacy-api-imports.mjs",
    "check:frontend-bundle": "node scripts/check-frontend-bundle-budget.mjs",
    "check:risk-guardrails": "node scripts/check-risk-guardrails.mjs",
    "check:data-safety": "node scripts/check-data-safety.mjs",
    "check:vercel-rewrites": "node scripts/check-vercel-rewrites.mjs",
    "sync:erp-access": "node scripts/sync-erp-access-policy.js",
    "smoke:tenants": "node scripts/smoke-tenants.js",
    "smoke:erp-acceptance": "node scripts/erp-acceptance-automated.mjs",
    "check:fcm": "node scripts/check-fcm-setup.mjs",
    "check:mobile-release-secrets": "node scripts/check-mobile-release-secrets.mjs",
    "setup:mobile-github-secrets": "node scripts/setup-mobile-github-secrets.mjs",
    "smoke:prod": "node scripts/production-smoke.js",
    "smoke:sales-ai": "node scripts/smoke-sales-ai.js",
    "setup:openai-railway": "node scripts/set-openai-railway.mjs",
    "smoke:staging": "node scripts/staging-smoke.js",
    "smoke:erp-fix:prod": "node scripts/verify-erp-fix-production.mjs",
    "smoke:setup-secrets": "node scripts/setup-smoke-github-secrets.js",
    "load:smoke": "node scripts/http-load-smoke.mjs",
    "test:e2e": "npm --prefix frontend run test:e2e",
    "test:e2e:staging": "npm --prefix frontend run test:e2e:staging",
    "test:backend": "npm run check:tracked-paths && npm run check:destructive-guards && npm run check:risk-guardrails && npm run check:vercel-rewrites && npm run sync:erp-access && npm --prefix backend test",
    "test:frontend": "npm run check:tracked-paths && npm run check:destructive-guards && npm run check:risk-guardrails && npm run check:vercel-rewrites && npm run sync:erp-access && npm --prefix frontend test && npm --prefix frontend run test:unit",
    "build:backend": "npm run sync:erp-access && cd backend && npm install --omit=dev",
    "build:frontend": "npm run sync:erp-access && cd frontend && npm run build && cd .. && npm run check:frontend-bundle",
    "deploy:railway": "npm run check:ci-parity:full && echo '✓ Ready for Railway deployment.'",
    "cleanup:safe": "npm --prefix backend run cleanup:safe"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/preset-react": "^7.28.5",
    "@eslint/js": "^9.15.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0"
  }
}
